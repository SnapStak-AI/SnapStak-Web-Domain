{
    "manifest_version": 3,
    "name": "SnapStak",
    "version": "2.0.0",
    "description": "Deconstruct any webpage. CON10X transforms it to production code.",
    "icons": {
        "16":  "icons/icon16.png",
        "32":  "icons/icon32.png",
        "48":  "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16":  "icons/icon16.png",
            "48":  "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_title": "SnapStak — Deconstruct the Web"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["http://*/*", "https://*/*"],
            "js": ["bridge.js"],
            "run_at": "document_idle",
            "all_frames": false
        }
    ],
    "permissions": [
        "activeTab",
        "scripting",
        "debugger",
        "storage",
        "declarativeNetRequest",
        "declarativeNetRequestWithHostAccess",
        "declarativeNetRequestFeedback"
    ],
    "host_permissions": [
        "http://*/*",
        "https://*/*",
        "http://localhost:5174/*"
    ],
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "csp_rules",
                "enabled": true,
                "path": "rules/csp_rules.json"
            }
        ]
    }
}