# ─────────────────────────────────────────────────────────────────────────────
# canva.env  —  Canva Connect API credentials
#
# SETUP
#   1. Go to https://www.canva.com/developers/
#   2. Click "Your integrations" → "Create an integration"
#   3. Name it something like "SnapStak CON10X"
#   4. Under Configuration:
#        - Note the Client ID shown on the page
#        - Click "Generate secret" — copy it immediately, it is shown ONCE
#   5. Under Scopes → check:  design:content:write
#   6. Under Return navigation → enable it, set URL to:
#        http://localhost:5174/api/canva/callback   (development)
#        https://yourdomain.com/api/canva/callback  (production)
#   7. Fill in the three values below and save this file.
#
# LOADING INTO THE SERVER
#   Windows (PowerShell — run before starting the server):
#     Get-Content canva.env | ForEach-Object {
#       if ($_ -match '^\s*([^#][^=]+?)\s*=\s*(.*)\s*$') {
#         [System.Environment]::SetEnvironmentVariable($Matches[1], $Matches[2], 'Process')
#       }
#     }
#
#   Windows (Command Prompt):
#     for /f "tokens=1,2 delims==" %i in (canva.env) do (
#       if not "%i"=="" if not "%i:~0,1%"=="#" set "%i=%j"
#     )
#
#   Linux / macOS:
#     export $(grep -v '^#' canva.env | xargs)
#
#   Or add to SnapStak.Wasm.Server/Properties/launchSettings.json under
#   environmentVariables for the profile you use.
#
# SECURITY
#   • Never commit this file to source control.
#   • Add  canva.env  to your .gitignore immediately.
#   • The client secret is equivalent to a password — treat it accordingly.
#   • For production, use a secrets manager (Azure Key Vault, AWS Secrets
#     Manager, or .NET User Secrets) instead of this file.
# ─────────────────────────────────────────────────────────────────────────────

# Your integration's Client ID from the Canva Developer Portal.
CANVA_CLIENT_ID=PASTE_YOUR_CLIENT_ID_HERE

# Your integration's client secret. Generated once — store it securely.
CANVA_CLIENT_SECRET=PASTE_YOUR_CLIENT_SECRET_HERE

# The OAuth redirect URL registered in the Canva Developer Portal.
# Must match EXACTLY — including http vs https and trailing slash.
# Development:
CANVA_REDIRECT_URI=http://localhost:5174/api/canva/callback
# Production (uncomment and update when deploying):
# CANVA_REDIRECT_URI=https://yourdomain.com/api/canva/callback