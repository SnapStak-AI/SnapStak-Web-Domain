@inherits LayoutComponentBase
@using SnapStak.Wasm.Client.Services
@using Microsoft.AspNetCore.Components.Routing
@inject LicenceService Licence
@inject NavigationManager Nav

<div class="snapstak-shell">
    <nav class="snapstak-nav">
        <div class="snapstak-nav__brand">
            <span class="snapstak-nav__logo">SnapStak</span>
            <span class="snapstak-nav__tag">CON10X</span>
        </div>
        <div class="snapstak-nav__links">
            <NavLink href="/" class="snapstak-nav__link" Match="NavLinkMatch.All">Transform</NavLink>
            <NavLink href="/sessions" class="snapstak-nav__link">Sessions</NavLink>
            <NavLink href="/transfer" class="snapstak-nav__link">Transfer</NavLink>
            <NavLink href="/settings" class="snapstak-nav__link">Settings</NavLink>
        </div>
    </nav>

    <main class="snapstak-main">
        @Body
    </main>
</div>

<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #0d0d0d;
        color: #e8e8e8;
        min-height: 100vh;
    }

    .snapstak-shell { display: flex; flex-direction: column; min-height: 100vh; }

    .snapstak-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 24px;
        height: 56px;
        background: #111;
        border-bottom: 1px solid #222;
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .snapstak-nav__brand { display: flex; align-items: center; gap: 8px; }
    .snapstak-nav__logo  { font-size: 18px; font-weight: 700; color: #fff; letter-spacing: -0.5px; }
    .snapstak-nav__tag   { font-size: 10px; font-weight: 600; color: #4af; background: #1a2a3a; padding: 2px 6px; border-radius: 4px; letter-spacing: 0.5px; }

    .snapstak-nav__links { display: flex; gap: 4px; }
    .snapstak-nav__link  { color: #999; text-decoration: none; font-size: 14px; padding: 6px 12px; border-radius: 6px; transition: all 0.15s; }
    .snapstak-nav__link:hover { color: #fff; background: #1e1e1e; }
    .snapstak-nav__link.active { color: #4af; background: #0a1a2a; }

    .snapstak-main { flex: 1; padding: 32px 24px; max-width: 1200px; margin: 0 auto; width: 100%; }
</style>
