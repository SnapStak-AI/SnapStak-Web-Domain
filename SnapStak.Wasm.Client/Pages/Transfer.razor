@page "/transfer"
@using SnapStak.Wasm.Client.Services
@inject MobilePairingService Pairing
@inject MobileFileTransferService FileTransfer
@implements IDisposable

<div style="display:flex;flex-direction:column;gap:14px;">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
        <div>
            <div style="font-size:21px;font-weight:500;color:#fff;">Transfer</div>
            <div style="font-size:13px;color:#555;margin-top:3px;">Sync deconstructed component files from paired SnapStak Mobile devices.</div>
        </div>
        @if (_pairedDevices.Count > 0)
        {
            <button class="@("xfr-sync-btn" + (_isSyncing ? " xfr-sync-btn--busy" : ""))"
                    @onclick="SyncAsync"
                    disabled="@_isSyncing">
                @if (_isSyncing)
                {
                    <span class="xfr-spinner"></span>
                    <span>Syncing&hellip;</span>
                }
                else
                {
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"
                         style="flex-shrink:0;">
                        <polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/>
                        <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4-4.64 4.36A9 9 0 0 1 3.51 15"/>
                    </svg>
                    <span>Sync</span>
                }
            </button>
        }
    </div>

    @if (_pairedDevices.Count == 0)
    {
        <div class="xfr-card xfr-card--empty">
            <div class="xfr-empty-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#333"
                     stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
                    <line x1="12" y1="18" x2="12.01" y2="18"/>
                </svg>
            </div>
            <div class="xfr-empty-title">No paired devices</div>
            <div class="xfr-empty-desc">Pair a device in <a href="/settings" class="xfr-link">Settings &rarr; Mobile Pairing</a> to sync files.</div>
        </div>
    }
    else
    {
        <div class="xfr-card">
            <div class="xfr-section-title">Paired devices</div>
            <div class="xfr-devices">
                @foreach (var device in _pairedDevices)
                {
                    <div class="xfr-device-row">
                        <div class="xfr-dot @(_isListening ? "xfr-dot--on" : "xfr-dot--off")"></div>
                        <span class="xfr-device-id" title="@device.DeviceId">@device.DeviceId[..Math.Min(8, device.DeviceId.Length)]&hellip;</span>
                        @if (!string.IsNullOrEmpty(device.MobileIp))
                        {
                            <span class="xfr-device-ip">@device.MobileIp</span>
                        }
                        <span class="xfr-device-date">Paired @device.PairedAt.ToString("d MMM yyyy")</span>
                    </div>
                }
            </div>
            @if (_isListening)
            {
                <div class="xfr-listen-status">
                    <span class="xfr-status-ok">&#9679; Ready to receive on port 5174</span>
                </div>
            }
        </div>

        @if (_syncResult != null)
        {
            <div class="xfr-banner xfr-banner--@(_syncResult.IsError ? "error" : "ok")">
                @if (_syncResult.IsError)
                {
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                }
                else
                {
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                }
                <span>@_syncResult.Message</span>
            </div>
        }

        <div class="xfr-card">
            <div class="xfr-section-title">Transferred files</div>

            @if (_files.Count == 0)
            {
                <div class="xfr-no-files">
                    No files transferred yet. Press <strong>Sync</strong> to pull files from SnapStak Mobile.
                </div>
            }
            else
            {
                <div class="xfr-file-list">
                    @foreach (var file in _files)
                    {
                        <div class="xfr-file-row">
                            <div class="xfr-file-header">
                                <span class="xfr-file-name">@file.Filename</span>
                                <span class="xfr-badge xfr-badge--@file.Status.ToString().ToLower()">@file.Status</span>
                            </div>
                            <div class="xfr-file-meta">
                                <span>@file.DeviceId[..Math.Min(8, file.DeviceId.Length)]&hellip;</span>
                                <span>@FormatBytes(file.SizeBytes)</span>
                                <span>@file.ReceivedAt.ToString("HH:mm:ss")</span>
                            </div>
                            @if (file.Status == FileTransferStatus.Ready && file.OutputPath != null)
                            {
                                <div class="xfr-file-path" title="@file.OutputPath">&rarr; @file.OutputPath</div>
                            }
                            @if (file.Status == FileTransferStatus.Error && file.ErrorMessage != null)
                            {
                                <div class="xfr-file-error">@file.ErrorMessage</div>
                            }
                            <div class="xfr-file-actions">
                                <button class="xfr-btn-ghost" @onclick="() => DismissFile(file.Id)">Dismiss</button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private List<PairedDevice>  _pairedDevices = new();
    private List<IncomingFile>  _files         = new();
    private bool                _isListening   = false;
    private bool                _isSyncing     = false;
    private SyncResultBanner?   _syncResult    = null;
    private System.Threading.Timer? _pollTimer;

    private sealed class SyncResultBanner
    {
        public bool   IsError { get; init; }
        public string Message { get; init; } = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        _pollTimer = new System.Threading.Timer(
            _ => InvokeAsync(async () => { await RefreshAsync(); StateHasChanged(); }),
            null,
            TimeSpan.FromSeconds(3),
            TimeSpan.FromSeconds(3));
    }

    private async Task RefreshAsync()
    {
        _pairedDevices = await Pairing.GetPairedDevicesAsync();
        _files         = await FileTransfer.GetFilesAsync();
        _isListening   = await FileTransfer.IsListeningAsync();
    }

    private async Task SyncAsync()
    {
        if (_isSyncing) return;
        _isSyncing  = true;
        _syncResult = null;
        StateHasChanged();

        try
        {
            var result = await FileTransfer.SyncFromMobileAsync();
            _syncResult = new SyncResultBanner
            {
                IsError = !result.Success,
                Message = result.Message,
            };
            _files = await FileTransfer.GetFilesAsync();
        }
        catch (Exception ex)
        {
            _syncResult = new SyncResultBanner { IsError = true, Message = ex.Message };
        }
        finally
        {
            _isSyncing = false;
            StateHasChanged();
        }
    }

    private async Task DismissFile(string fileId)
    {
        await FileTransfer.DismissFileAsync(fileId);
        _files = await FileTransfer.GetFilesAsync();
        StateHasChanged();
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }

    public void Dispose() => _pollTimer?.Dispose();
}

<style>
.xfr-card              { background:#141414; border:0.5px solid #1e1e1e; border-radius:11px; padding:16px; }
.xfr-card--empty       { display:flex; flex-direction:column; align-items:center; justify-content:center;
                          padding:48px 24px; gap:12px; text-align:center; }
.xfr-empty-icon        { opacity:.4; }
.xfr-empty-title       { font-size:14px; font-weight:500; color:#777; }
.xfr-empty-desc        { font-size:12px; color:#444; line-height:1.5; }
.xfr-link              { color:#38a3f8; text-decoration:none; }
.xfr-link:hover        { text-decoration:underline; }

.xfr-sync-btn          { display:flex; align-items:center; gap:7px; background:#0e1f33;
                          border:0.5px solid #1e4a7a; border-radius:8px; color:#4af;
                          font-size:13px; font-weight:500; padding:8px 16px; cursor:pointer;
                          transition:all .15s; white-space:nowrap; flex-shrink:0; }
.xfr-sync-btn:hover:not(:disabled) { background:#102540; border-color:#2a6aaa; }
.xfr-sync-btn:disabled { opacity:.5; cursor:not-allowed; }

.xfr-spinner           { width:13px; height:13px; border:2px solid #1e4a7a;
                          border-top-color:#4af; border-radius:50%;
                          animation:xfr-spin .7s linear infinite; flex-shrink:0; }
@@keyframes xfr-spin   { to { transform:rotate(360deg); } }

.xfr-section-title     { font-size:10px; font-weight:500; color:#555; text-transform:uppercase;
                          letter-spacing:.7px; margin-bottom:10px; }

.xfr-devices           { display:flex; flex-direction:column; gap:6px; margin-bottom:10px; }
.xfr-device-row        { display:flex; align-items:center; gap:8px; }
.xfr-dot               { width:7px; height:7px; border-radius:50%; flex-shrink:0; }
.xfr-dot--on           { background:#4f8; box-shadow:0 0 5px #4f8; }
.xfr-dot--off          { background:#333; }
.xfr-device-id         { font-size:13px; color:#aaa; font-family:monospace; }
.xfr-device-ip         { font-size:11px; color:#555; font-family:monospace; }
.xfr-device-date       { font-size:11px; color:#444; margin-left:auto; }
.xfr-listen-status     { font-size:12px; padding:8px 10px; border-radius:7px; background:#0d0d0d;
                          border:0.5px solid #1a1a1a; }
.xfr-status-ok         { color:#4f8; }

.xfr-banner            { display:flex; align-items:center; gap:8px; font-size:12px;
                          padding:9px 13px; border-radius:8px; }
.xfr-banner--ok        { background:#0a140a; border:0.5px solid #1a3a1a; color:#4f8; }
.xfr-banner--error     { background:#1a0a0a; border:0.5px solid #440000; color:#f88; }

.xfr-no-files          { font-size:12px; color:#444; padding:16px 0; text-align:center; line-height:1.7; }
.xfr-no-files strong   { color:#666; }
.xfr-file-list         { display:flex; flex-direction:column; gap:8px; }
.xfr-file-row          { border:0.5px solid #1e1e1e; border-radius:8px; padding:10px 12px;
                          background:#0e0e0e; }
.xfr-file-header       { display:flex; align-items:center; justify-content:space-between; gap:8px;
                          margin-bottom:4px; }
.xfr-file-name         { font-size:13px; color:#ccc; font-weight:500; font-family:monospace; }
.xfr-badge             { font-size:10px; font-weight:500; padding:2px 8px; border-radius:4px;
                          text-transform:lowercase; letter-spacing:.3px; flex-shrink:0; }
.xfr-badge--received   { background:#1a1a2a; border:0.5px solid #3a3a6a; color:#88f; }
.xfr-badge--decrypting { background:#1a1400; border:0.5px solid #443300; color:#ca8; }
.xfr-badge--ready      { background:#0a140a; border:0.5px solid #1a3a1a; color:#4f8; }
.xfr-badge--error      { background:#1a0a0a; border:0.5px solid #440000; color:#f88; }
.xfr-file-meta         { display:flex; gap:12px; font-size:11px; color:#444; margin-bottom:4px; }
.xfr-file-path         { font-size:11px; color:#38a3f8; font-family:monospace; overflow:hidden;
                          text-overflow:ellipsis; white-space:nowrap; margin-bottom:4px; }
.xfr-file-error        { font-size:11px; color:#f88; margin-bottom:4px; }
.xfr-file-actions      { display:flex; gap:6px; margin-top:4px; }
.xfr-btn-ghost         { background:transparent; color:#444; border:0.5px solid #222; border-radius:6px;
                          padding:4px 10px; font-size:11px; cursor:pointer; }
.xfr-btn-ghost:hover   { border-color:#444; color:#888; }
</style>
